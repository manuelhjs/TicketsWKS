@*
    Formulario de creación EMBEBIDO (antes era un modal). Se ubica antes de los filtros.
    Colapsable para no ocupar espacio permanente. Mantiene las validaciones.
*@
<div class="card mb-3">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span><i class="bi bi-plus-circle"></i> Nuevo ticket</span>
        <button class="btn btn-sm btn-outline-secondary" type="button"
                data-bs-toggle="collapse" data-bs-target="#createFormBody" aria-expanded="false">
            Mostrar / ocultar
        </button>
    </div>
    <div class="collapse" id="createFormBody">
        <div class="card-body">
            <form id="createTicketForm" novalidate>
                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label">Área <span class="text-danger">*</span></label>
                        <select id="createArea" class="form-select" required>
                            <option value="">Seleccione…</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Tipo de solicitud <span class="text-danger">*</span></label>
                        <select id="createType" name="TicketTypeId" class="form-select" required>
                            <option value="">Seleccione…</option>
                        </select>
                    </div>
                    <div class="col-md-4 d-none" data-area-field="CAL">
                        <label class="form-label">Departamento de calidad <span class="text-danger">*</span></label>
                        <select name="QualityDepartment" class="form-select">
                            <option value="">Seleccione…</option>
                            <option value="Producción">Producción</option>
                            <option value="Comercial">Comercial</option>
                            <option value="Sistemas">Sistemas</option>
                        </select>
                    </div>
                    <div class="col-md-3 d-none" data-area-field="CAL">
                        <label class="form-label">Monto <span class="text-danger">*</span></label>
                        <input type="number" step="0.01" name="Amount" class="form-control" placeholder="0.00" />
                    </div>
                    <div class="col-md-3 d-none" data-area-field="CAL">
                        <label class="form-label">Cantidad <span class="text-danger">*</span></label>
                        <input type="number" step="1" name="Quantity" class="form-control" placeholder="0" />
                    </div>
                    <div class="col-md-4 d-none" data-area-field="PD">
                        <label class="form-label">Máquina <span class="text-danger">*</span></label>
                        <input type="text" name="Machine" class="form-control" placeholder="Ingrese la máquina…" />
                    </div>
                    <div class="col-12">
                        <label class="form-label">Descripción <span class="text-danger">*</span></label>
                        <textarea name="Description" class="form-control" rows="3" required placeholder="Describe tu solicitud…"></textarea>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Archivo adjunto (opcional)</label>
                        <input type="file" id="createFile" class="form-control" />
                    </div>
                </div>
                <div class="mt-3 d-flex gap-2">
                    <button type="submit" class="btn btn-primary">Guardar ticket</button>
                    <button type="reset" class="btn btn-outline-secondary" id="createResetBtn">Limpiar</button>
                </div>
            </form>
        </div>
    </div>
</div>
