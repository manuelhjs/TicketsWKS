@*
    Formulario de creación EMBEBIDO (visible por defecto). Validaciones también en backend.
*@
<div class="card mb-3">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span><i class="bi bi-plus-circle"></i> Nuevo ticket</span>
        <button class="btn btn-sm btn-outline-secondary" type="button"
                data-bs-toggle="collapse" data-bs-target="#createFormBody" aria-expanded="true">
            Mostrar / ocultar
        </button>
    </div>
    <div class="collapse show" id="createFormBody">
        <div class="card-body">
            <form id="createTicketForm" novalidate>
                <div class="row g-3">
                    <!-- Solicitante -->
                    <div class="col-md-6">
                        <label class="form-label">Solicitante <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <select id="createSolicitante" name="SolicitanteId" class="form-select" required></select>
                            <button class="btn btn-outline-secondary" type="button" id="btnNuevoSolicitante" title="Nuevo solicitante">
                                <i class="bi bi-person-plus"></i> Nuevo
                            </button>
                        </div>
                    </div>

                    <!-- Correo -->
                    <div class="col-md-3">
                        <label class="form-label">Correo del solicitante</label>
                        <input type="email" id="createCorreo" name="Correo" class="form-control" placeholder="correo@empresa.com" />
                    </div>

                    <!-- Celular -->
                    <div class="col-md-3">
                        <label class="form-label">Celular</label>
                        <input type="tel" id="createCelular" name="Celular" class="form-control" maxlength="10"
                               inputmode="numeric" pattern="\d{10}" placeholder="10 dígitos" />
                    </div>

                    <!-- Tipo de solicitud -->
                    <div class="col-md-6">
                        <label class="form-label d-block">Tipo de solicitud <span class="text-danger">*</span></label>
                        <div class="form-check form-check-inline">
                            <input class="form-check-input" type="radio" name="TipoSolicitud" id="tipoInc" value="1" checked>
                            <label class="form-check-label" for="tipoInc">
                                Incidencia
                                <i class="bi bi-info-circle text-muted" data-bs-toggle="tooltip"
                                   title="Algo que está fallando o dejó de funcionar."></i>
                            </label>
                        </div>
                        <div class="form-check form-check-inline">
                            <input class="form-check-input" type="radio" name="TipoSolicitud" id="tipoReq" value="2">
                            <label class="form-check-label" for="tipoReq">
                                Requerimiento
                                <i class="bi bi-info-circle text-muted" data-bs-toggle="tooltip"
                                   title="Una solicitud nueva o mejora."></i>
                            </label>
                        </div>
                    </div>

                    <!-- Prioridad -->
                    <div class="col-md-6">
                        <label class="form-label d-block">Prioridad <span class="text-danger">*</span></label>
                        <div id="prioridadRadios" class="d-inline"></div>
                    </div>

                    <!-- Clasificación -->
                    <div class="col-md-6">
                        <label class="form-label">Clasificación <span class="text-danger">*</span></label>
                        <select id="createClasificacion" name="ClasificacionId" class="form-select" required></select>
                    </div>

                    <!-- Categoría -->
                    <div class="col-md-6">
                        <label class="form-label">Categoría <span class="text-danger">*</span></label>
                        <select id="createCategoria" name="CategoriaId" class="form-select" required></select>
                    </div>

                    <!-- Descripción -->
                    <div class="col-12">
                        <label class="form-label">Descripción <span class="text-danger">*</span></label>
                        <textarea id="createDescripcion" name="Descripcion" class="form-control" rows="3" maxlength="2000"
                                  required placeholder="Describe el problema o la solicitud de la forma más clara posible…"></textarea>
                        <div class="form-text"><span id="descCount">0</span>/2000</div>
                    </div>

                    <!-- Adjuntos -->
                    <div class="col-12">
                        <label class="form-label">Adjuntar evidencias</label>
                        <input type="file" id="createFiles" class="form-control" multiple
                               accept=".pdf,.jpg,.jpeg,.png,.ppt,.pptx,.doc,.docx,.xls,.xlsx,.txt,.csv" />
                        <div class="form-text">
                            Formatos: PDF, JPG, PNG, PPT/PPTX, DOC/DOCX, XLS/XLSX, TXT, CSV.
                            Máx. 10&nbsp;MB por archivo, hasta 5 archivos.
                            <br />Si no puedes adjuntar (por tamaño o tipo), comparte un enlace de Google Drive
                            o envíalo a <a href="mailto:plataformas.soporte@impulsoraint.com">plataformas.soporte@impulsoraint.com</a>.
                        </div>
                    </div>
                </div>

                <!-- Leyendas fijas -->
                <div class="alert alert-info small mt-3 mb-2">
                    <i class="bi bi-clock"></i>
                    <strong>Horario de atención:</strong> Lunes a Viernes de 8:00 a 18:00 hrs.
                    Solicitudes fuera de este horario solo se atienden si son Prioridad Alta.
                    <br />
                    <i class="bi bi-exclamation-triangle"></i>
                    Las incidencias serán evaluadas para confirmar si la prioridad seleccionada es la correcta.
                    Los tiempos son SLA de referencia, no un compromiso contractual.
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">Guardar ticket</button>
                    <button type="reset" class="btn btn-outline-secondary" id="createResetBtn">Limpiar</button>
                </div>
            </form>
        </div>
    </div>
</div>
