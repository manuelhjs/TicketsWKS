@*
    Formulario de creación EMBEBIDO (visible por defecto). Validaciones también en backend.
*@
<div class="card mb-3">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span><i class="bi bi-plus-circle"></i> Nuevo ticket</span>
        <button class="btn btn-sm btn-outline-secondary" type="button"
                data-bs-toggle="collapse" data-bs-target="#createFormBody" aria-expanded="true">
            Mostrar / ocultar
        </button>
    </div>
    <div class="collapse show" id="createFormBody">
        <div class="card-body">
            <form id="createTicketForm" novalidate>
                <div class="row g-3">
                    <!-- Solicitante -->
                    <div class="col-md-6">
                        <label class="form-label">Solicitante <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <select id="createSolicitante" name="SolicitanteId" class="form-select" required>
                                <option value="">Seleccione…</option>
                            </select>
                            <button class="btn btn-outline-secondary" type="button" id="btnNuevoSolicitante" title="Nuevo solicitante">
                                <i class="bi bi-person-plus"></i> Nuevo
                            </button>
                        </div>
                    </div>

                    <!-- Correo -->
                    <div class="col-md-3">
                        <label class="form-label">Correo del solicitante</label>
                        <input type="email" id="createCorreo" name="Correo" class="form-control" placeholder="correo@empresa.com" />
                    </div>

                    <!-- Celular -->
                    <div class="col-md-3">
                        <label class="form-label">Celular</label>
                        <input type="tel" id="createCelular" name="Celular" class="form-control" maxlength="10"
                               inputmode="numeric" pattern="\d{10}" placeholder="10 dígitos" />
                    </div>

                    <!-- Tipo de solicitud -->
                    <div class="col-md-6">
                        <label class="form-label d-block">Tipo de solicitud <span class="text-danger">*</span></label>
                        <div class="form-check form-check-inline">
                            <input class="form-check-input" type="radio" name="TipoSolicitud" id="tipoInc" value="1" checked>
                            <label class="form-check-label" for="tipoInc">
                                Incidencia
                                <i class="bi bi-info-circle text-muted" data-bs-toggle="tooltip"
                                   title="Algo que está fallando o dejó de funcionar."></i>
                            </label>
                        </div>
                        <div class="form-check form-check-inline">
                            <input class="form-check-input" type="radio" name="TipoSolicitud" id="tipoReq" value="2">
                            <label class="form-check-label" for="tipoReq">
                                Requerimiento
                                <i class="bi bi-info-circle text-muted" data-bs-toggle="tooltip"
                                   title="Una solicitud nueva o mejora."></i>
                            </label>
                        </div>
                    </div>

                    <!-- Prioridad -->
                    <div class="col-md-6">
                        <label class="form-label d-block">Prioridad <span class="text-danger">*</span></label>
                        <div id="prioridadRadios" class="d-inline"></div>
                    </div>

                    <!-- Clasificación (dropdown personalizado con "Otro…") -->
                    <div class="col-md-6">
                        <label class="form-label">Clasificación <span class="text-danger">*</span></label>
                        <div class="tk-dropdown" id="ddClasificacion">
                            <input type="hidden" name="ClasificacionId" id="createClasificacionValue" />
                            <button type="button" class="tk-dropdown-toggle" id="createClasificacionToggle">
                                <span class="tk-dropdown-label tk-placeholder" id="createClasificacionLabel">Seleccione…</span>
                                <span class="tk-caret">▾</span>
                            </button>
                            <div class="tk-dropdown-menu" id="createClasificacionMenu"></div>
                        </div>
                    </div>

                    <!-- Categoría (dropdown personalizado con "Otro…") -->
                    <div class="col-md-6">
                        <label class="form-label">Categoría <span class="text-danger">*</span></label>
                        <div class="tk-dropdown" id="ddCategoria">
                            <input type="hidden" name="CategoriaId" id="createCategoriaValue" />
                            <button type="button" class="tk-dropdown-toggle" id="createCategoriaToggle">
                                <span class="tk-dropdown-label tk-placeholder" id="createCategoriaLabel">Seleccione…</span>
                                <span class="tk-caret">▾</span>
                            </button>
                            <div class="tk-dropdown-menu" id="createCategoriaMenu"></div>
                        </div>
                    </div>

                    <!-- Descripción -->
                    <div class="col-12">
                        <label class="form-label">Descripción <span class="text-danger">*</span></label>
                        <textarea id="createDescripcion" name="Descripcion" class="form-control" rows="3" maxlength="2000"
                                  required placeholder="Describe el problema o la solicitud de la forma más clara posible…"></textarea>
                        <div class="form-text"><span id="descCount">0</span>/2000</div>
                    </div>

                    <!-- Adjuntos -->
                    <div class="col-12">
                        <label class="form-label">Adjuntar evidencias</label>
                        <input type="file" id="createFiles" class="form-control" multiple
                               accept=".pdf,.jpg,.jpeg,.png,.ppt,.pptx,.doc,.docx,.xls,.xlsx,.txt,.csv" />
                        <div class="form-text">
                            PDF, JPG, PNG, PPT, DOC, XLS, TXT, CSV · máx. 10&nbsp;MB · hasta 5 archivos
                            <br />Si no puedes adjuntar, comparte un enlace de Drive o envíalo a
                            <a href="mailto:plataformas.soporte@impulsoraint.com">plataformas.soporte@impulsoraint.com</a>.
                        </div>
                    </div>
                </div>

                <!-- Leyendas fijas (compactas) -->
                <div class="row g-2 mt-1 mb-3">
                    <div class="col-md-6">
                        <div class="alert alert-info small mb-0 py-2 px-3 h-100 d-flex align-items-center gap-2">
                            <i class="bi bi-clock-fill"></i>
                            <div><strong style="color:var(--tk-accent);">Horario:</strong> L-V 8:00–18:00 hrs. Fuera de horario, solo Prioridad Alta.</div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="alert alert-warning small mb-0 py-2 px-3 h-100 d-flex align-items-center gap-2">
                            <i class="bi bi-exclamation-triangle-fill"></i>
                            <div><strong style="color:var(--tk-warn);">Nota:</strong> Las incidencias serán evaluadas para confirmar si la prioridad seleccionada es la correcta, no un compromiso contractual.</div>
                        </div>
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">Guardar ticket</button>
                    <button type="reset" class="btn btn-outline-secondary" id="createResetBtn">Limpiar</button>
                </div>
            </form>
        </div>
    </div>
</div>
