@*
    Modal de DETALLE de ticket (reemplaza la edición inline).
    Se abre al hacer clic en una fila / Id. Los campos editables se muestran
    según el rol (TI edita; Usuario solo lee y puede comentar/adjuntar).
*@
<div class="modal fade" id="ticketDetailModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Ticket <span id="dtlId"></span> — <span id="dtlType"></span></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <dl class="row mb-3 small">
                    <dt class="col-sm-3">Área</dt><dd class="col-sm-3" id="dtlArea"></dd>
                    <dt class="col-sm-3">Estatus</dt><dd class="col-sm-3"><span id="dtlStatusBadge" class="badge"></span></dd>

                    <dt class="col-sm-3">Solicitante</dt><dd class="col-sm-3" id="dtlRequester"></dd>
                    <dt class="col-sm-3">Departamento</dt><dd class="col-sm-3" id="dtlDepartment"></dd>

                    <dt class="col-sm-3">Creación</dt><dd class="col-sm-3" id="dtlCreated"></dd>
                    <dt class="col-sm-3">Cierre</dt><dd class="col-sm-3" id="dtlClosed"></dd>

                    <dt class="col-sm-3">Depto. Calidad</dt><dd class="col-sm-3" id="dtlQuality"></dd>
                    <dt class="col-sm-3">Máquina</dt><dd class="col-sm-3" id="dtlMachine"></dd>

                    <dt class="col-sm-3">Monto</dt><dd class="col-sm-3" id="dtlAmount"></dd>
                    <dt class="col-sm-3">Cantidad</dt><dd class="col-sm-3" id="dtlQuantity"></dd>

                    <dt class="col-sm-3">Descripción</dt><dd class="col-sm-9" id="dtlDescription"></dd>

                    <dt class="col-sm-3">Anexo</dt>
                    <dd class="col-sm-9">
                        <span id="dtlAttachment" class="me-2"></span>
                        <button type="button" class="btn btn-sm btn-outline-primary" id="btnDtlUpload">Adjuntar archivo</button>
                    </dd>
                </dl>

                <!-- Edición -->
                <div id="dtlManage" class="border rounded p-3 mb-3 bg-light">
                    <h6 class="mb-3">Gestión</h6>
                    <div class="row g-2 align-items-end">
                        <div class="col-md-3">
                            <label class="form-label">Estatus</label>
                            <select id="dtlStatus" class="form-select form-select-sm">
                                <option value="1">Creado</option>
                                <option value="2">En Proceso</option>
                                <option value="3">Cerrado</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Fecha estimada de cierre</label>
                            <input type="date" id="dtlEstimate" class="form-control form-control-sm" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Responsable</label>
                            <select id="dtlResponsible" class="form-select form-select-sm"></select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Tipo (categoría)</label>
                            <input type="text" id="dtlCategory" class="form-control form-control-sm" />
                        </div>
                    </div>
                    <div class="mt-3 d-flex gap-2">
                        <button type="button" class="btn btn-sm btn-primary" id="btnDtlSave">Guardar cambios</button>
                        <button type="button" class="btn btn-sm btn-outline-danger" id="btnDtlInactivate">Inactivar ticket</button>
                    </div>
                </div>

                <!-- Comentarios -->
                <h6 class="mb-2">Comentarios</h6>
                <div id="dtlComments" class="comments-list mb-3">
                    <p class="text-muted text-center small">Cargando…</p>
                </div>
                <form id="dtlCommentForm" class="d-flex gap-2">
                    <input type="hidden" id="dtlCommentTicketId" />
                    <input type="text" id="dtlCommentBody" class="form-control form-control-sm" placeholder="Escribe un comentario…" required />
                    <button type="submit" class="btn btn-sm btn-primary">Enviar</button>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
            </div>
        </div>
    </div>
</div>
