@*
    Modal de DETALLE / edición del ticket, con pestañas.
    Estatus: al cambiarlo es obligatorio un comentario (se registra en HistorialEstatus).
*@
<div class="modal fade" id="ticketDetailModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-xl modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Ticket <span id="dtlId"></span></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <ul class="nav nav-tabs mb-3" role="tablist">
                    <li class="nav-item"><button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tabDetalle" type="button">Detalle</button></li>
                    <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tabComentarios" type="button">Comentarios</button></li>
                    <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tabHistorial" type="button">Historial de estatus</button></li>
                    <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tabBitacora" type="button">Bitácora</button></li>
                </ul>

                <div class="tab-content">
                    <!-- DETALLE / EDICIÓN -->
                    <div class="tab-pane fade show active" id="tabDetalle">
                        <div class="row g-2 small mb-2">
                            <div class="col-md-4"><strong>Solicitante:</strong> <span id="dtlSolicitante"></span></div>
                            <div class="col-md-4"><strong>Estatus:</strong> <span id="dtlEstatusActual" class="badge bg-secondary"></span></div>
                            <div class="col-md-4"><strong>Creación:</strong> <span id="dtlCreated"></span></div>
                        </div>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Correo</label>
                                <input type="email" id="dtlCorreo" class="form-control form-control-sm" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Celular</label>
                                <input type="tel" id="dtlCelular" class="form-control form-control-sm" maxlength="10" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Tipo de solicitud</label>
                                <select id="dtlTipo" class="form-select form-select-sm">
                                    <option value="1">Incidencia</option>
                                    <option value="2">Requerimiento</option>
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Prioridad</label>
                                <select id="dtlPrioridad" class="form-select form-select-sm"></select>
                            </div>
                            <div class="col-md-4"></div>
                            <div class="col-md-6">
                                <label class="form-label">Clasificación</label>
                                <select id="dtlClasificacion" class="form-select form-select-sm"></select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Categoría</label>
                                <select id="dtlCategoria" class="form-select form-select-sm"></select>
                            </div>
                            <div class="col-12">
                                <label class="form-label">Descripción</label>
                                <textarea id="dtlDescripcion" class="form-control form-control-sm" rows="3" maxlength="2000"></textarea>
                            </div>
                        </div>
                        <div class="mt-2">
                            <button type="button" class="btn btn-sm btn-primary" id="btnDtlSave">Guardar cambios</button>
                        </div>

                        <hr />

                        <!-- Cambio de estatus (comentario obligatorio) -->
                        <div class="border rounded p-2 bg-light mb-3">
                            <h6 class="mb-2">Cambiar estatus</h6>
                            <div class="row g-2 align-items-end">
                                <div class="col-md-3">
                                    <label class="form-label mb-0 small">Nuevo estatus</label>
                                    <select id="dtlEstatus" class="form-select form-select-sm"></select>
                                </div>
                                <div class="col-md-7">
                                    <label class="form-label mb-0 small">Comentario <span class="text-danger">*</span></label>
                                    <input type="text" id="dtlEstatusComentario" class="form-control form-control-sm"
                                           placeholder="Obligatorio al cambiar de estatus" />
                                </div>
                                <div class="col-md-2">
                                    <button type="button" class="btn btn-sm btn-warning w-100" id="btnDtlChangeStatus">Aplicar</button>
                                </div>
                            </div>
                        </div>

                        <!-- Responsable -->
                        <div class="row g-2 align-items-end mb-3">
                            <div class="col-md-6">
                                <label class="form-label mb-0 small">Responsable</label>
                                <select id="dtlResponsable" class="form-select form-select-sm"></select>
                            </div>
                            <div class="col-md-3">
                                <button type="button" class="btn btn-sm btn-outline-primary w-100" id="btnDtlAssign">Asignar</button>
                            </div>
                            <div class="col-md-3">
                                <button type="button" class="btn btn-sm btn-outline-danger w-100" id="btnDtlInactivate">Inactivar</button>
                            </div>
                        </div>

                        <!-- Adjuntos -->
                        <h6 class="mb-2">Evidencias</h6>
                        <ul id="dtlAdjuntos" class="list-unstyled small mb-2"></ul>
                        <div class="input-group input-group-sm">
                            <input type="file" id="dtlFiles" class="form-control" multiple
                                   accept=".pdf,.jpg,.jpeg,.png,.ppt,.pptx,.doc,.docx,.xls,.xlsx,.txt,.csv" />
                            <button type="button" class="btn btn-outline-primary" id="btnDtlUpload">Subir</button>
                        </div>
                    </div>

                    <!-- COMENTARIOS -->
                    <div class="tab-pane fade" id="tabComentarios">
                        <div id="dtlComments" class="comments-list mb-3"></div>
                        <form id="dtlCommentForm" class="d-flex gap-2">
                            <input type="hidden" id="dtlCommentTicketId" />
                            <input type="text" id="dtlCommentBody" class="form-control form-control-sm" placeholder="Escribe un comentario…" required />
                            <button type="submit" class="btn btn-sm btn-primary">Enviar</button>
                        </form>
                    </div>

                    <!-- HISTORIAL DE ESTATUS -->
                    <div class="tab-pane fade" id="tabHistorial">
                        <table class="table table-sm">
                            <thead><tr><th>Fecha</th><th>De</th><th>A</th><th>Comentario</th><th>Usuario</th></tr></thead>
                            <tbody id="dtlHistorial"></tbody>
                        </table>
                    </div>

                    <!-- BITÁCORA (log general, solo lectura) -->
                    <div class="tab-pane fade" id="tabBitacora">
                        <table class="table table-sm">
                            <thead><tr><th>Fecha</th><th>Acción</th><th>Detalle</th><th>Antes</th><th>Después</th><th>Usuario</th></tr></thead>
                            <tbody id="dtlLog"></tbody>
                        </table>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
            </div>
        </div>
    </div>
</div>
