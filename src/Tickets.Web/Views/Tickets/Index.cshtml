@model TicketsIndexViewModel
@{
    ViewData["Title"] = "Tickets";
}

<link rel="stylesheet" href="https://cdn.datatables.net/1.13.8/css/dataTables.bootstrap5.min.css" />
<link rel="stylesheet" href="https://cdn.datatables.net/fixedcolumns/4.3.0/css/fixedColumns.bootstrap5.min.css" />
<link rel="stylesheet" href="~/css/tickets.css" asp-append-version="true" />

<div class="tickets-page">

    <!-- Cabecera con datos del usuario -->
    <div class="card mb-3 user-header">
        <div class="card-body d-flex flex-wrap justify-content-between align-items-center">
            <div class="d-flex align-items-center gap-3">
                <div class="user-avatar"><i class="bi bi-person-circle"></i></div>
                <div>
                    <div class="user-name">@Model.FullName</div>
                    <div class="user-meta">
                        <span><i class="bi bi-building"></i> @Model.DepartmentName</span>
                        <span class="mx-2">·</span>
                        <span><i class="bi bi-briefcase"></i> @Model.Position</span>
                    </div>
                </div>
            </div>
            <div class="d-flex align-items-center gap-3">
                <div class="stat"><span class="stat-value" id="statTotal">@Model.Dashboard.Total</span><span class="stat-label">Total</span></div>
                <div class="stat text-warning"><span class="stat-value" id="statPorAsignar">@Model.Dashboard.PorAsignar</span><span class="stat-label">Por asignar</span></div>
                <div class="stat text-info"><span class="stat-value" id="statEnCurso">@Model.Dashboard.EnCurso</span><span class="stat-label">En curso</span></div>
                <div class="stat text-success"><span class="stat-value" id="statFinalizados">@Model.Dashboard.Finalizados</span><span class="stat-label">Finalizados</span></div>
            </div>
        </div>
    </div>

    <!-- Formulario de creación (antes de los filtros) -->
    @await Html.PartialAsync("_CreateTicketForm")

    <!-- Filtros (recargan la tabla automáticamente al cambiar) -->
    <div class="card mb-3">
        <div class="card-body">
            <div class="filters-bar">
                <div class="filter-field">
                    <label class="form-label form-label-sm mb-0 small">Desde</label>
                    <input type="date" id="filterDesde" class="form-control form-control-sm" />
                </div>
                <div class="filter-field">
                    <label class="form-label form-label-sm mb-0 small">Hasta</label>
                    <input type="date" id="filterHasta" class="form-control form-control-sm" />
                </div>
                <select id="filterEstatus" class="form-select form-select-sm filter-select"><option value="">Estatus</option></select>
                <select id="filterClasificacion" class="form-select form-select-sm filter-select"><option value="">Clasificación</option></select>
                <select id="filterPrioridad" class="form-select form-select-sm filter-select"><option value="">Prioridad</option></select>
                <select id="filterSolicitante" class="form-select form-select-sm filter-select"><option value="">Solicitante</option></select>
                <select id="filterTipo" class="form-select form-select-sm filter-select">
                    <option value="">Tipo</option>
                    <option value="1">Incidencia</option>
                    <option value="2">Requerimiento</option>
                </select>
                <button type="button" class="btn-clear" id="btnClearFilters">Limpiar filtros</button>
            </div>
        </div>
    </div>

    <!-- Tabla -->
    <div class="card">
        <div class="card-body">
            <!-- Se reubica junto al buscador de DataTables en initComplete -->
            <button type="button" class="btn-export d-none" id="btnExportTickets">↓ Exportar</button>
            <table class="table table-sm table-hover table-striped w-100" id="ticketsTable">
                <thead>
                    <tr>
                        <th>Id</th>
                        <th>Solicitante</th>
                        <th>Tipo</th>
                        <th>Clasificación</th>
                        <th>Categoría</th>
                        <th>Prioridad</th>
                        <th>Estatus</th>
                        <th>Responsable</th>
                        <th>Creación</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    </div>
</div>

@await Html.PartialAsync("_TicketDetailModal")
@await Html.PartialAsync("_CatalogModals")

@section Scripts {
    <script src="https://cdn.datatables.net/1.13.8/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.8/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdn.datatables.net/fixedcolumns/4.3.0/js/dataTables.fixedColumns.min.js"></script>
    <script>
        window.ticketsConfig = {
            currentEmpleadoId: @Model.CurrentEmpleadoId,
            urls: {
                getTickets: '@Url.Action("GetTickets")',
                exportTickets: '@Url.Action("Export")',
                getTicket: '@Url.Action("GetTicket")',
                getDashboard: '@Url.Action("GetDashboard")',
                getClasificaciones: '@Url.Action("GetClasificaciones")',
                getCategorias: '@Url.Action("GetCategorias")',
                getPrioridades: '@Url.Action("GetPrioridades")',
                getEstatus: '@Url.Action("GetEstatus")',
                addClasificacion: '@Url.Action("AddClasificacion")',
                addCategoria: '@Url.Action("AddCategoria")',
                getEmpleados: '@Url.Action("GetEmpleados")',
                addEmpleado: '@Url.Action("AddEmpleado")',
                create: '@Url.Action("Create")',
                update: '@Url.Action("Update")',
                changeStatus: '@Url.Action("ChangeStatus")',
                assignResponsable: '@Url.Action("AssignResponsable")',
                setInactive: '@Url.Action("SetInactive")',
                getComments: '@Url.Action("GetComments")',
                addComment: '@Url.Action("AddComment")',
                getHistorial: '@Url.Action("GetHistorial")',
                getLog: '@Url.Action("GetLog")',
                getAdjuntos: '@Url.Action("GetAdjuntos")',
                uploadAdjuntos: '@Url.Action("UploadAdjuntos")',
                downloadAdjunto: '@Url.Action("DownloadAdjunto")'
            }
        };
    </script>
    <script src="~/js/tickets.js" asp-append-version="true"></script>
}
