@model TicketsIndexViewModel
@{
    ViewData["Title"] = "Tickets";
}

<link rel="stylesheet" href="https://cdn.datatables.net/1.13.8/css/dataTables.bootstrap5.min.css" />
<link rel="stylesheet" href="~/css/tickets.css" asp-append-version="true" />

<div class="tickets-page">

    <!-- 1. Cabecera con datos del usuario -->
    <div class="card mb-3 user-header">
        <div class="card-body d-flex flex-wrap justify-content-between align-items-center">
            <div class="d-flex align-items-center gap-3">
                <div class="user-avatar"><i class="bi bi-person-circle"></i></div>
                <div>
                    <div class="user-name">@Model.FullName</div>
                    <div class="user-meta">
                        <span><i class="bi bi-building"></i> @Model.DepartmentName</span>
                        <span class="mx-2">·</span>
                        <span><i class="bi bi-briefcase"></i> @Model.Position</span>
                    </div>
                </div>
                <span class="badge @(Model.IsIt ? "bg-primary" : "bg-secondary") ms-2">
                    Modo @(Model.IsIt ? "TI" : "Usuario")
                </span>
            </div>

            <div class="d-flex align-items-center gap-3">
                <div class="stat text-warning">
                    <span class="stat-value" id="statOpen">@Model.Dashboard.TotalOpen</span>
                    <span class="stat-label">Creados</span>
                </div>
                @if (Model.IsIt)
                {
                    <div class="stat text-info">
                        <span class="stat-value" id="statInProgress">@Model.Dashboard.TotalInProgress</span>
                        <span class="stat-label">En Proceso</span>
                    </div>
                }
                <div class="stat text-success">
                    <span class="stat-value" id="statClosed">@Model.Dashboard.TotalClosed</span>
                    <span class="stat-label">Cerrados</span>
                </div>
            </div>
        </div>
    </div>

    <!-- 2. Formulario de creación embebido (antes de los filtros) -->
    @await Html.PartialAsync("_CreateTicketForm")

    <!-- 3. Filtros -->
    <div class="card mb-3">
        <div class="card-body">
            <div class="btn-group mb-3 flex-wrap" role="group" aria-label="Estatus">
                <input type="radio" class="btn-check" name="statusFilter" id="stAll" value="" autocomplete="off" checked>
                <label class="btn btn-outline-secondary btn-sm" for="stAll">Todos</label>

                <input type="radio" class="btn-check" name="statusFilter" id="stOpen" value="1" autocomplete="off">
                <label class="btn btn-outline-warning btn-sm" for="stOpen">Creados</label>

                @if (Model.IsIt)
                {
                    <input type="radio" class="btn-check" name="statusFilter" id="stProg" value="2" autocomplete="off">
                    <label class="btn btn-outline-info btn-sm" for="stProg">En Proceso</label>
                }

                <input type="radio" class="btn-check" name="statusFilter" id="stClosed" value="3" autocomplete="off">
                <label class="btn btn-outline-success btn-sm" for="stClosed">Cerrados</label>
            </div>

            <div class="row g-2">
                <div class="col-6 col-md">
                    <select id="filterPeriod" class="form-select form-select-sm">
                        <option value="lastMonth">Último mes</option>
                        <option value="last3Months">3 meses</option>
                        <option value="last6Months">6 meses</option>
                        <option value="lastYear">1 año</option>
                        <option value="last2Years" selected>2 años</option>
                        <option value="all">Todo</option>
                    </select>
                </div>
                @if (Model.IsIt)
                {
                    <div class="col-6 col-md">
                        <select id="filterRequester" class="form-select form-select-sm"><option value="">Solicitante</option></select>
                    </div>
                    <div class="col-6 col-md">
                        <select id="filterType" class="form-select form-select-sm"><option value="">Clasificación</option></select>
                    </div>
                    <div class="col-6 col-md">
                        <select id="filterDepartment" class="form-select form-select-sm"><option value="">Departamento</option></select>
                    </div>
                    <div class="col-6 col-md">
                        <select id="filterResponsible" class="form-select form-select-sm"><option value="">Responsable</option></select>
                    </div>
                }
                <div class="col-6 col-md-auto d-flex gap-2">
                    <button id="btnApplyFilters" class="btn btn-sm btn-primary flex-fill">Filtrar</button>
                    <button id="btnClearFilters" class="btn btn-sm btn-outline-secondary flex-fill">Limpiar</button>
                </div>
            </div>
        </div>
    </div>

    <!-- 4. Tabla (DataTables) -->
    <div class="card">
        <div class="card-body">
            <table class="table table-sm table-hover table-striped w-100" id="ticketsTable">
                <thead>
                    <tr>
                        <th>Id</th>
                        <th>Clasificación</th>
                        <th>Solicitante</th>
                        <th>Departamento</th>
                        <th>Responsable</th>
                        <th>Creación</th>
                        <th>Estatus</th>
                        <th>Est. cierre</th>
                        <th>Cierre</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    </div>
</div>

@await Html.PartialAsync("_TicketDetailModal")

@section Scripts {
    <script src="https://cdn.datatables.net/1.13.8/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.8/js/dataTables.bootstrap5.min.js"></script>
    <script>
        window.ticketsConfig = {
            isIt: @Json.Serialize(Model.IsIt),
            urls: {
                getTickets: '@Url.Action("GetTickets")',
                getTicket: '@Url.Action("GetTicket")',
                getDashboard: '@Url.Action("GetDashboard")',
                getFilterOptions: '@Url.Action("GetFilterOptions")',
                getAreas: '@Url.Action("GetAreas")',
                getTicketTypes: '@Url.Action("GetTicketTypes")',
                create: '@Url.Action("Create")',
                updateStatus: '@Url.Action("UpdateStatus")',
                updateEstimatedCloseDate: '@Url.Action("UpdateEstimatedCloseDate")',
                updateResponsible: '@Url.Action("UpdateResponsible")',
                updateCategory: '@Url.Action("UpdateCategory")',
                setInactive: '@Url.Action("SetInactive")',
                getComments: '@Url.Action("GetComments")',
                addComment: '@Url.Action("AddComment")',
                uploadAttachment: '@Url.Action("UploadAttachment")',
                downloadAttachment: '@Url.Action("DownloadAttachment")'
            }
        };
    </script>
    <script src="~/js/tickets.js" asp-append-version="true"></script>
}
