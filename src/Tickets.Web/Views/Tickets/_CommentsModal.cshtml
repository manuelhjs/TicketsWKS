<div class="modal fade" id="commentsModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Comentarios — Ticket <span id="commentsTicketId"></span></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <div id="commentsList" class="comments-list mb-3">
                    <p class="text-muted text-center">Cargando…</p>
                </div>
                <form id="addCommentForm" class="d-flex gap-2">
                    <input type="hidden" name="TicketId" id="commentTicketIdInput" />
                    <input type="text" name="Body" id="commentBody" class="form-control" placeholder="Escribe un comentario…" required />
                    <button type="submit" class="btn btn-primary">Enviar</button>
                </form>
            </div>
        </div>
    </div>
</div>
