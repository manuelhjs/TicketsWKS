@{
    ViewData["Title"] = "Catálogos de Tickets";
}

<link rel="stylesheet" href="~/css/tickets.css" asp-append-version="true" />

<div class="tickets-page">

    <!-- Encabezado -->
    <div class="card mb-3">
        <div class="card-body d-flex align-items-start gap-3 py-3">
            <span style="font-size:18px;">⚙️</span>
            <div>
                <div class="fw-bold" style="font-size:16px;">Catálogos de Tickets</div>
                <div class="user-meta">Administra los catálogos que usa el alta de tickets.</div>
            </div>
        </div>
    </div>

    <!-- Tabs + contenido -->
    <div class="card">
        <ul class="nav opciones-tabs" role="tablist">
            <li class="nav-item"><button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tabClasif" type="button">Clasificaciones</button></li>
            <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tabCat" type="button">Categorías</button></li>
            <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tabPri" type="button">Prioridades</button></li>
            <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tabEst" type="button">Estatus</button></li>
        </ul>
        <div class="card-body">
            <div class="tab-content">
                <!-- Clasificaciones -->
                <div class="tab-pane fade show active" id="tabClasif">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div class="fw-bold" style="font-size:15px;">Clasificaciones</div>
                        <button class="btn btn-sm btn-primary" id="btnAddClasif">＋ Agregar</button>
                    </div>
                    <div class="border rounded-3 overflow-hidden">
                        <table class="table admin-table mb-0">
                            <thead><tr><th>Nombre</th><th>Estado</th><th class="text-end">Acciones</th></tr></thead>
                            <tbody id="tblClasif"></tbody>
                        </table>
                    </div>
                </div>

                <!-- Categorías -->
                <div class="tab-pane fade" id="tabCat">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div class="fw-bold" style="font-size:15px;">Categorías</div>
                        <button class="btn btn-sm btn-primary" id="btnAddCat">＋ Agregar</button>
                    </div>
                    <div class="border rounded-3 overflow-hidden">
                        <table class="table admin-table mb-0">
                            <thead><tr><th>Clasificación</th><th>Nombre</th><th>Estado</th><th class="text-end">Acciones</th></tr></thead>
                            <tbody id="tblCat"></tbody>
                        </table>
                    </div>
                </div>

                <!-- Prioridades -->
                <div class="tab-pane fade" id="tabPri">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div class="fw-bold" style="font-size:15px;">Prioridades</div>
                        <button class="btn btn-sm btn-primary" id="btnAddPri">＋ Agregar</button>
                    </div>
                    <div class="border rounded-3 overflow-hidden">
                        <table class="table admin-table mb-0">
                            <thead><tr><th>Nombre</th><th>Descripción</th><th>Orden</th><th>Estado</th><th class="text-end">Acciones</th></tr></thead>
                            <tbody id="tblPri"></tbody>
                        </table>
                    </div>
                </div>

                <!-- Estatus -->
                <div class="tab-pane fade" id="tabEst">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div class="fw-bold" style="font-size:15px;">Estatus</div>
                        <button class="btn btn-sm btn-primary" id="btnAddEst">＋ Agregar</button>
                    </div>
                    <div class="border rounded-3 overflow-hidden">
                        <table class="table admin-table mb-0">
                            <thead><tr><th>Nombre</th><th>Orden</th><th>Cierra ticket</th><th>Estado</th><th class="text-end">Acciones</th></tr></thead>
                            <tbody id="tblEst"></tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@await Html.PartialAsync("_OptionModals")

@section Scripts {
    <script>
        window.optionsConfig = {
            urls: {
                getClasificaciones: '@Url.Action("GetClasificaciones")',
                upsertClasificacion: '@Url.Action("UpsertClasificacion")',
                toggleClasificacion: '@Url.Action("ToggleClasificacion")',
                getCategorias: '@Url.Action("GetCategorias")',
                upsertCategoria: '@Url.Action("UpsertCategoria")',
                toggleCategoria: '@Url.Action("ToggleCategoria")',
                getPrioridades: '@Url.Action("GetPrioridades")',
                upsertPrioridad: '@Url.Action("UpsertPrioridad")',
                togglePrioridad: '@Url.Action("TogglePrioridad")',
                getEstatus: '@Url.Action("GetEstatus")',
                upsertEstatus: '@Url.Action("UpsertEstatus")',
                toggleEstatus: '@Url.Action("ToggleEstatus")'
            }
        };
    </script>
    <script src="~/js/options.js" asp-append-version="true"></script>
}
